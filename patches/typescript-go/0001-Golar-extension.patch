diff --git a/pkg/module/resolver.go b/pkg/module/resolver.go
index 73af6a1a9..cb67b3bf9 100644
--- a/pkg/module/resolver.go
+++ b/pkg/module/resolver.go
@@ -1446,8 +1446,23 @@ func (r *resolutionState) tryAddingExtensions(extensionless string, extensions e
 				return resolved
 			}
 		}
+		if originalExtension == "" {
+			for _, e := range tspath.ExtraExtensionless {
+				if resolved := r.tryExtension(e, extensionless, false, onlyRecordFailures); !resolved.shouldContinueSearching() {
+					return resolved
+				}
+			}
+		}
 		return continueSearching()
 	default:
+		for _, e := range tspath.ExtraExtensions {
+			if e == originalExtension {
+				if resolved := r.tryExtension(originalExtension, extensionless, false, onlyRecordFailures); !resolved.shouldContinueSearching() {
+					return resolved
+				}
+				return continueSearching()
+			}
+		}
 		if extensions&extensionsDeclaration != 0 && !tspath.IsDeclarationFileName(extensionless+originalExtension) {
 			if resolved := r.tryExtension(".d"+originalExtension+".ts", extensionless, false, onlyRecordFailures); !resolved.shouldContinueSearching() {
 				return resolved
diff --git a/pkg/module/util.go b/pkg/module/util.go
index fe0e514e2..224f64b28 100644
--- a/pkg/module/util.go
+++ b/pkg/module/util.go
@@ -169,6 +169,11 @@ func GetResolutionDiagnostic(options *core.CompilerOptions, resolvedModule *Reso
 	case tspath.ExtensionJson:
 		return needResolveJsonModule()
 	default:
+		for _, e := range tspath.ExtraExtensions {
+			if e == resolvedModule.Extension {
+				return nil
+			}
+		}
 		return needAllowArbitraryExtensions()
 	}
 }
diff --git a/pkg/outputpaths/outputpaths.go b/pkg/outputpaths/outputpaths.go
index 18744c40c..217275a0b 100644
--- a/pkg/outputpaths/outputpaths.go
+++ b/pkg/outputpaths/outputpaths.go
@@ -205,6 +205,11 @@ func getDeclarationEmitExtensionForPath(fileName string) string {
 	} else if tspath.FileExtensionIs(fileName, tspath.ExtensionJson) {
 		return ".d.json.ts"
 	}
+	for _, e := range tspath.ExtraExtensions {
+		if tspath.FileExtensionIs(fileName, e) && !tspath.ShouldRemoveExtension(e) {
+			return e + tspath.ExtensionDts
+		}
+	}
 	return tspath.ExtensionDts
 }
 
diff --git a/pkg/tspath/extension.go b/pkg/tspath/extension.go
index 7b6578363..1bc75d852 100644
--- a/pkg/tspath/extension.go
+++ b/pkg/tspath/extension.go
@@ -23,6 +23,8 @@ const (
 )
 
 var (
+	ExtraExtensions                                = []string{}
+	ExtraExtensionless                             = []string{}
 	SupportedDeclarationExtensions                 = []string{ExtensionDts, ExtensionDcts, ExtensionDmts}
 	SupportedTSImplementationExtensions            = []string{ExtensionTs, ExtensionTsx, ExtensionMts, ExtensionCts}
 	supportedTSExtensionsForExtractExtension       = []string{ExtensionDts, ExtensionDcts, ExtensionDmts, ExtensionTs, ExtensionTsx, ExtensionMts, ExtensionCts}
@@ -37,12 +39,33 @@ var (
 	ExtensionsNotSupportingExtensionlessResolution = []string{ExtensionMts, ExtensionDmts, ExtensionMjs, ExtensionCts, ExtensionDcts, ExtensionCjs}
 )
 
+func RegisterSupportedExtension(ext string) {
+	ExtraExtensions = append(ExtraExtensions, ext)
+	AllSupportedExtensions[0] = append(AllSupportedExtensions[0], ext)
+	AllSupportedExtensionsWithJson[0] = append(AllSupportedExtensionsWithJson[0], ext)
+	SupportedTSExtensions[0] = append(SupportedTSExtensions[0], ext)
+	SupportedTSExtensionsWithJson[0] = append(SupportedTSExtensionsWithJson[0], ext)
+	SupportedTSExtensionsFlat = append(SupportedTSExtensionsFlat, ext)
+	SupportedTSExtensionsWithJsonFlat = append(SupportedTSExtensionsWithJsonFlat, ext)
+}
+
+func RegisterSupportedExtensionless(ext string) {
+	ExtraExtensionless = append(ExtraExtensionless, ext)
+}
+
 func ExtensionIsTs(ext string) bool {
 	return ext == ExtensionTs || ext == ExtensionTsx || ext == ExtensionDts || ext == ExtensionMts || ext == ExtensionDmts || ext == ExtensionCts || ext == ExtensionDcts || len(ext) >= 7 && ext[:3] == ".d." && ext[len(ext)-3:] == ".ts"
 }
 
 var extensionsToRemove = []string{ExtensionDts, ExtensionDmts, ExtensionDcts, ExtensionMjs, ExtensionMts, ExtensionCjs, ExtensionCts, ExtensionTs, ExtensionJs, ExtensionTsx, ExtensionJsx, ExtensionJson}
 
+func RegisterExtensionToRemove(ext string) {
+	extensionsToRemove = append(extensionsToRemove, ext)
+}
+func ShouldRemoveExtension(ext string) bool {
+	return slices.Contains(extensionsToRemove, ext)
+}
+
 func RemoveFileExtension(path string) string {
 	// Remove any known extension even if it has more than one dot
 	for _, ext := range extensionsToRemove {
@@ -134,6 +157,11 @@ func GetDeclarationEmitExtensionForPath(path string) string {
 	case FileExtensionIsOneOf(path, []string{ExtensionJson}):
 		return `.d.json.ts` // Drive-by redefinition of json declaration file output name so if it's ever enabled, it behaves well
 	default:
+		for _, e := range ExtraExtensions {
+			if FileExtensionIs(path, e) && !slices.Contains(extensionsToRemove, e) {
+				return e + ExtensionDts
+			}
+		}
 		return ExtensionDts
 	}
 }
