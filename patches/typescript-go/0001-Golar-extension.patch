From 19a44289c5753c0999e38119feb382e01709c0cc Mon Sep 17 00:00:00 2001
From: auvred <aauvred@gmail.com>
Date: Sun, 1 Mar 2026 12:22:09 +0300
Subject: [PATCH] Golar extension

---
 cmd/tsgo/main.go               |  1 +
 pkg/ast/ast.go                 | 12 ++++++++++++
 pkg/compiler/program.go        | 31 +++++++++++++++++++++++++++++--
 pkg/diagnostics/diagnostics.go |  9 +++++++++
 pkg/module/resolver.go         | 15 +++++++++++++++
 pkg/module/util.go             |  5 +++++
 pkg/outputpaths/outputpaths.go |  5 +++++
 pkg/tspath/extension.go        | 28 ++++++++++++++++++++++++++++
 8 files changed, 104 insertions(+), 2 deletions(-)

diff --git a/cmd/tsgo/main.go b/cmd/tsgo/main.go
index 03bcb5064..65d452bf5 100644
--- a/cmd/tsgo/main.go
+++ b/cmd/tsgo/main.go
@@ -3,6 +3,7 @@ package main
 import (
 	"os"
 
+	_ "github.com/auvred/golar"
 	"github.com/microsoft/typescript-go/pkg/execute"
 )
 
diff --git a/pkg/ast/ast.go b/pkg/ast/ast.go
index 0e1f89740..d91be6626 100644
--- a/pkg/ast/ast.go
+++ b/pkg/ast/ast.go
@@ -10967,6 +10967,10 @@ type SourceFile struct {
 	LocalsContainerBase
 	compositeNodeBase
 
+	GolarLanguageData       any
+	WrapSemanticDiagnostics func([]*Diagnostic) []*Diagnostic
+	WrapDiagnostics         func([]*Diagnostic) []*Diagnostic
+
 	// Fields set by NewSourceFile
 	fileName       string // For debugging convenience
 	parseOptions   SourceFileParseOptions
@@ -11053,10 +11057,18 @@ func (node *SourceFile) Text() string {
 	return node.text
 }
 
+func (node *SourceFile) SetText(text string) {
+	node.text = text
+}
+
 func (node *SourceFile) FileName() string {
 	return node.parseOptions.FileName
 }
 
+func (node *SourceFile) SetParseOptions(opts SourceFileParseOptions) {
+	node.parseOptions = opts
+}
+
 func (node *SourceFile) Path() tspath.Path {
 	return node.parseOptions.Path
 }
diff --git a/pkg/compiler/program.go b/pkg/compiler/program.go
index 14d7cd309..71afa1bd9 100644
--- a/pkg/compiler/program.go
+++ b/pkg/compiler/program.go
@@ -253,7 +253,15 @@ func (p *Program) GetSourceFileFromReference(origin *ast.SourceFile, ref *ast.Fi
 	return nil
 }
 
+type golarExt struct {
+	WrapCompilerHost func(config *tsoptions.ParsedCommandLine, host CompilerHost) CompilerHost
+}
+
+var GolarExt = &golarExt{}
+
 func NewProgram(opts ProgramOptions) *Program {
+	// TODO: don't wrap already wrapped host
+	opts.Host = GolarExt.WrapCompilerHost(opts.Config, opts.Host)
 	p := &Program{opts: opts}
 	p.processedFiles = processAllProgramFiles(p.opts, p.SingleThreaded())
 	p.initCheckerPool()
@@ -474,7 +482,13 @@ func (p *Program) collectDiagnosticsFromFiles(ctx context.Context, sourceFiles [
 
 func (p *Program) GetSyntacticDiagnostics(ctx context.Context, sourceFile *ast.SourceFile) []*ast.Diagnostic {
 	return p.collectDiagnostics(ctx, sourceFile, false /*concurrent*/, func(_ context.Context, file *ast.SourceFile) []*ast.Diagnostic {
-		return core.Concatenate(file.Diagnostics(), file.JSDiagnostics())
+		diags := file.Diagnostics()
+		jsDiags := file.JSDiagnostics()
+		if file.WrapDiagnostics != nil {
+			diags = file.WrapDiagnostics(diags)
+			jsDiags = file.WrapDiagnostics(jsDiags)
+		}
+		return core.Concatenate(diags, jsDiags)
 	})
 }
 
@@ -485,7 +499,11 @@ func (p *Program) GetBindDiagnostics(ctx context.Context, sourceFile *ast.Source
 		p.BindSourceFiles()
 	}
 	return p.collectDiagnostics(ctx, sourceFile, false /*concurrent*/, func(_ context.Context, file *ast.SourceFile) []*ast.Diagnostic {
-		return file.BindDiagnostics()
+		diags := file.BindDiagnostics()
+		if file.WrapDiagnostics != nil {
+			diags = file.WrapDiagnostics(diags)
+		}
+		return diags
 	})
 }
 
@@ -518,6 +536,9 @@ func (p *Program) GetIncludeProcessorDiagnostics(sourceFile *ast.SourceFile) []*
 		return nil
 	}
 	filtered, _ := p.getDiagnosticsWithPrecedingDirectives(sourceFile, p.includeProcessor.getDiagnostics(p).GetDiagnosticsForFile(sourceFile.FileName()))
+	if sourceFile.WrapDiagnostics != nil {
+		filtered = sourceFile.WrapDiagnostics(filtered)
+	}
 	return filtered
 }
 
@@ -1131,6 +1152,9 @@ func (p *Program) getBindAndCheckDiagnosticsForFile(ctx context.Context, sourceF
 
 	isPlainJS := ast.IsPlainJSFile(sourceFile, compilerOptions.CheckJs)
 	if isPlainJS {
+		if sourceFile.WrapSemanticDiagnostics != nil {
+			diags = sourceFile.WrapSemanticDiagnostics(diags)
+		}
 		return core.Filter(diags, func(d *ast.Diagnostic) bool {
 			return plainJSErrors.Has(d.Code())
 		})
@@ -1150,6 +1174,9 @@ func (p *Program) getBindAndCheckDiagnosticsForFile(ctx context.Context, sourceF
 			filtered = append(filtered, ast.NewDiagnostic(sourceFile, directive.Loc, diagnostics.Unused_ts_expect_error_directive))
 		}
 	}
+	if sourceFile.WrapSemanticDiagnostics != nil {
+		filtered = sourceFile.WrapSemanticDiagnostics(filtered)
+	}
 	return filtered
 }
 
diff --git a/pkg/diagnostics/diagnostics.go b/pkg/diagnostics/diagnostics.go
index 108857f1b..5e1edc37e 100644
--- a/pkg/diagnostics/diagnostics.go
+++ b/pkg/diagnostics/diagnostics.go
@@ -59,6 +59,15 @@ func (m *Message) ReportsUnnecessary() bool           { return m.reportsUnnecess
 func (m *Message) ElidedInCompatibilityPyramid() bool { return m.elidedInCompatibilityPyramid }
 func (m *Message) ReportsDeprecated() bool            { return m.reportsDeprecated }
 
