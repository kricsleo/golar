diff --git a/pkg/compiler/program.go b/pkg/compiler/program.go
index b9d487f14..f40025907 100644
--- a/pkg/compiler/program.go
+++ b/pkg/compiler/program.go
@@ -254,7 +254,19 @@ func (p *Program) GetSourceFileFromReference(origin *ast.SourceFile, ref *ast.Fi
 	return nil
 }
 
+type golarExt struct {
+	WrapCompilerHost    func(base CompilerHost, configName string) CompilerHost
+	ReportingSourceFile func(file *ast.SourceFile) *ast.SourceFile
+}
+
+var GolarExt = &golarExt{}
+
 func NewProgram(opts ProgramOptions) *Program {
+	configName := ""
+	if opts.Config != nil && opts.Config.ConfigFile != nil && opts.Config.ConfigFile.SourceFile != nil {
+		configName = opts.Config.ConfigFile.SourceFile.FileName()
+	}
+	opts.Host = GolarExt.WrapCompilerHost(opts.Host, configName)
 	p := &Program{opts: opts}
 	p.processedFiles = processAllProgramFiles(p.opts, p.SingleThreaded())
 	p.initCheckerPool()
@@ -482,6 +494,9 @@ func (p *Program) GetSyntacticDiagnostics(ctx context.Context, sourceFile *ast.S
 		if ast.IsSourceFileJS(file) && !ast.IsCheckJSEnabledForFile(file, p.Options()) {
 			diags = append(diags, getAdditionalJSSyntacticDiagnostics(file, p.Options())...)
 		}
+		if file.WrapDiagnostics != nil {
+			diags = file.WrapDiagnostics(diags)
+		}
 		return diags
 	})
 }
@@ -524,7 +539,11 @@ func (p *Program) GetBindDiagnostics(ctx context.Context, sourceFile *ast.Source
 		p.BindSourceFiles()
 	}
 	return p.collectDiagnostics(ctx, sourceFile, false /*concurrent*/, func(_ context.Context, file *ast.SourceFile) []*ast.Diagnostic {
-		return file.BindDiagnostics()
+		diags := file.BindDiagnostics()
+		if file.WrapDiagnostics != nil {
+			diags = file.WrapDiagnostics(diags)
+		}
+		return diags
 	})
 }
 
@@ -557,6 +576,9 @@ func (p *Program) GetIncludeProcessorDiagnostics(sourceFile *ast.SourceFile) []*
 		return nil
 	}
 	filtered, _ := p.getDiagnosticsWithPrecedingDirectives(sourceFile, p.includeProcessor.getDiagnostics(p).GetDiagnosticsForFile(sourceFile.FileName()))
+	if sourceFile.WrapDiagnostics != nil {
+		filtered = sourceFile.WrapDiagnostics(filtered)
+	}
 	return filtered
 }
 
@@ -1219,6 +1241,9 @@ func (p *Program) getBindAndCheckDiagnosticsForFile(ctx context.Context, sourceF
 
 	isPlainJS := ast.IsPlainJSFile(sourceFile, compilerOptions.CheckJs)
 	if isPlainJS {
+		if sourceFile.WrapSemanticDiagnostics != nil {
+			diags = sourceFile.WrapSemanticDiagnostics(diags)
+		}
 		return core.Filter(diags, func(d *ast.Diagnostic) bool {
 			return plainJSErrors.Has(d.Code())
 		})
@@ -1238,6 +1263,9 @@ func (p *Program) getBindAndCheckDiagnosticsForFile(ctx context.Context, sourceF
 			filtered = append(filtered, ast.NewDiagnostic(sourceFile, directive.Loc, diagnostics.Unused_ts_expect_error_directive))
 		}
 	}
+	if sourceFile.WrapSemanticDiagnostics != nil {
+		filtered = sourceFile.WrapSemanticDiagnostics(filtered)
+	}
 	return filtered
 }
 
