diff --git a/pkg/module/util.go b/pkg/module/util.go
index fe0e514e2..f88e5ba91 100644
--- a/pkg/module/util.go
+++ b/pkg/module/util.go
@@ -169,6 +169,11 @@ func GetResolutionDiagnostic(options *core.CompilerOptions, resolvedModule *Reso
 	case tspath.ExtensionJson:
 		return needResolveJsonModule()
 	default:
+		for _, e := range tspath.ExtraExtensions {
+			if e == resolvedModule.Extension {
