{
	"name": "golar",
	"version": "0.1.3",
	"type": "module",
	"engines": {
		"node": ">=22.12.0"
	},
	"bin": "./src/bin.ts",
	"exports": {
		"./unstable": "./src/unstable.ts",
		"./unstable-tsgo": "./src/unstable-tsgo.ts"
	},
	"files": [
		"./dist"
	],
	"license": "MIT",
	"author": "auvred <aauvred@gmail.com> (https://github.com/auvred)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/auvred/golar.git",
		"directory": "packages/golar"
	},
	"bugs": "https://github.com/auvred/golar/issues",
	"homepage": "https://github.com/auvred/golar/tree/main/packages/golar#readme",
	"publishConfig": {
		"access": "public",
		"bin": "./dist/bin.js",
		"exports": {
			"./unstable": "./dist/unstable.js",
			"./unstable-tsgo": "./dist/unstable-tsgo.js"
		},
		"executableFiles": [
			"./dist/bin.js"
		]
	},
	"dependencies": {
		"@golar/util": "workspace:*"
	},
	"optionalDependencies": {
		"@golar/win32-x64": "workspace:*",
		"@golar/linux-x64": "workspace:*",
		"@golar/linux-arm64": "workspace:*",
		"@golar/darwin-x64": "workspace:*",
		"@golar/darwin-arm64": "workspace:*"
	}
}
